# Scoracle Data - Environment Template
#
# This file is committed and holds safe defaults / placeholders only.
# Copy to .env.local and fill in real values there (.env.local is gitignored).
#
# Both files are loaded at startup; .env.local wins on conflict.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Priority in Go config: DATABASE_PRIVATE_URL > RAILWAY_DATABASE_URL > DATABASE_URL
# Local dev default (KingSpec NVMe Postgres):
#   postgresql://scoracle:YOUR_PASSWORD@localhost:5432/scoracle?sslmode=disable
# Railway production is injected via RAILWAY_DATABASE_URL in the platform env.
DATABASE_PRIVATE_URL=
DATABASE_URL=

# Go database pool
DB_POOL_MIN_CONNS=2
DB_POOL_MAX_CONNS=10
DB_POOL_MAX_LIFE_MINUTES=30

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:4321,http://localhost:5173
CORS_PRODUCTION_ORIGINS=https://scoracle.com,https://www.scoracle.com

# Cache and rate limiting
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_WARMUP_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Provider keys (fill in .env.local)
# -----------------------------------------------------------------------------
SPORTMONKS_API_TOKEN=
BALLDONTLIE_API_KEY=
API_SPORTS_KEY=

# -----------------------------------------------------------------------------
# Integrations (fill in .env.local)
# -----------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_LIST_NBA=
TWITTER_LIST_NFL=
TWITTER_LIST_FOOTBALL=
TWITTER_CACHE_TTL_SECONDS=1200

FIREBASE_CREDENTIALS_FILE=
