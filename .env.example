# Scoracle Data API - Environment Variables
# Copy this file to .env and fill in real values.

# -----------------------------------------------------------------------------
# Database (Railway Postgres)
# -----------------------------------------------------------------------------
# Priority order: DATABASE_PRIVATE_URL > RAILWAY_DATABASE_URL > DATABASE_URL
# Railway automatically sets RAILWAY_DATABASE_URL when connecting a Postgres service
DATABASE_PRIVATE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# RAILWAY_DATABASE_URL=
# DATABASE_URL=

# Go database pool
DB_POOL_MIN_CONNS=2
DB_POOL_MAX_CONNS=10
DB_POOL_MAX_LIFE_MINUTES=30

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:4321,http://localhost:5173
CORS_PRODUCTION_ORIGINS=https://scoracle.com,https://www.scoracle.com

# Cache and rate limiting
CACHE_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Third-party integrations
# -----------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=
# Per-sport curated X List IDs (lazy cache; empty = sport feed disabled)
TWITTER_LIST_NBA=
TWITTER_LIST_NFL=
TWITTER_LIST_FOOTBALL=
# Cache TTL for sport feeds; default 1200 (20 min)
TWITTER_CACHE_TTL_SECONDS=1200
NEWS_API_KEY=

# Push notifications
FIREBASE_CREDENTIALS_FILE=

# -----------------------------------------------------------------------------
# Python seeder
# -----------------------------------------------------------------------------
BALLDONTLIE_API_KEY=
SPORTMONKS_API_TOKEN=
