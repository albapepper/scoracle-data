[Unit]
Description=Cloudflare Tunnel for Scoracle
After=network-online.target scoracle-api.service
Wants=network-online.target

[Service]
Type=simple
# Uses ~/.cloudflared/config.yml for tunnel + ingress configuration.
# See scripts/hosting/cloudflared-config.example.yml for what belongs there.
ExecStart=/usr/bin/cloudflared --no-autoupdate tunnel run
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
